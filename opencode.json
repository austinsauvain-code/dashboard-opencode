{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "autoupdate": true,
  "permission": {
    "bash(python3*)": "allow",
    "bash(unzip*)": "allow",
    "bash(cp*)": "allow",
    "bash(mkdir*)": "allow",
    "bash(cat*)": "allow",
    "bash(head*)": "allow",
    "bash(wc*)": "allow",
    "bash(ls*)": "allow",
    "bash(explorer.exe*)": "allow",
    "bash(rm -rf /*)": "deny",
    "write(output/*)": "allow",
    "write(AGENTS.md)": "deny"
  }
}
